# Receiver / merchant wallet. Address only; do not put the receiver private key here.
SERVER_ADDRESS=0xReceiverWalletAddress

# Payer / agent wallet. Test private key only; never use a real production wallet.
# The payer address derived from this key must be funded with Base Sepolia USDC.
CLIENT_TEST_PK=0xFundedPayerPrivateKey

# Signup-free x402 facilitator for Base Sepolia testnet.
X402_FACILITATOR_URL=https://www.x402.org/facilitator

# Base Sepolia RPC URL. Used by helper scripts and some x402 helpers.
EVM_RPC_URL=https://sepolia.base.org
